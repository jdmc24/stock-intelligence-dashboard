# Backend
ANTHROPIC_API_KEY=
# Optional — defaults to claude-sonnet-4-6. See Anthropic models overview if you get 404 on model.
ANTHROPIC_MODEL=claude-sonnet-4-6
# EarningsCall (required for tickers beyond free-tier AAPL/MSFT demo)
EARNINGSCALL_API_KEY=
SEC_USER_AGENT=EarningsCallAnalyzer/0.1 (contact: you@example.com)
API_BEARER_TOKEN=dev-token
# SQLite file path — not an API key; no cloud DB credential needed for V1
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Regulatory pipeline automation (optional)
# In-process: set true while uvicorn runs — background ingest + enrich on an interval.
REGULATORY_SCHEDULER_ENABLED=false
REGULATORY_SCHEDULER_INTERVAL_MINUTES=360
REGULATORY_SCHEDULER_RUN_ON_STARTUP=true
REGULATORY_SCHEDULER_INGEST_DAYS=3
REGULATORY_SCHEDULER_ENRICH_LIMIT=10
# Cron alternative (no in-process scheduler): cd backend && python -m app.regulatory_pipeline

# Frontend (Next.js)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_BEARER_TOKEN=dev-token
